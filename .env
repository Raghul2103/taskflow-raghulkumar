# Backend Configuration
PORT=5000
NODE_ENV=production
JWT_SECRET=your_super_secret_jwt_key_12345

# MongoDB Configuration (Internal Docker Network)
# Using 'db' as the hostname which is the service name in docker-compose.yml
MONGODB_URI=mongodb://root:password@db:27017/todo?authSource=admin

# MongoDB Root Credentials (Used by the 'db' service)
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=password

# Frontend URL (Used for CORS in backend)
FRONTEND_URL=http://localhost:80
